# Committed defaults for local development. Do NOT put secrets here —
# for machine-specific overrides or secrets, copy values into a
# `.env.local` file instead (already gitignored, and it wins over this file).

# Controls how docker-entrypoint.sh starts the container:
#   development -> `npm run dev` (Vite dev server + HMR)
#   production  -> `npm run build` then nginx serves the built dist/
APP_ENV=development

# Base URL the Vue app uses for REST API calls. Must be prefixed with
# VITE_ to be exposed to client code by Vite (see src/config/env.ts).
VITE_API_BASE_URL=http://localhost:8000/api
